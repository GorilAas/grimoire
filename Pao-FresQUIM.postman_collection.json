{
  "info": {
    "name": "Pão FresQUIM — API",
    "description": "Collection completa do backend Pão FresQUIM (Spring Boot + Supabase/PostgreSQL).\n\nBase URL: http://localhost:8080\n\nAutenticação: após fazer login, copie o `token` retornado e cole na variável de coleção `token`. Todas as requests usam `Bearer {{token}}` automaticamente.",
    "_postman_id": "paofresquim-2026-v2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token",   "value": "",                      "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "Auth",
      "description": "Autenticação JWT. Rota pública — não exige Bearer token.",
      "item": [
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var json = pm.response.json();",
                "if (json.token) { pm.collectionVariables.set('token', json.token); }"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"admin@paofresquim.com\",\n  \"senha\": \"Padaria@123\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "[401] Credenciais inválidas",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"naoexiste@email.com\",\n  \"senha\": \"senhaerrada\"\n}"
            }
          }
        }
      ]
    },

